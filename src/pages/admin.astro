<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Manager</title>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof window.netlifyIdentity === 'undefined') {
        console.error('[Identity] Widget script failed to load');
        document.body.innerHTML = '<p style="padding:2rem;font-family:sans-serif;">Netlify Identity widget failed to load. Check your network connection.</p>';
        return;
      }

      netlifyIdentity.on('init', function(user) {
        if (!user) {
          console.log('[Identity] Not logged in, opening login modal');
          netlifyIdentity.open('login');
        } else {
          console.log('[Identity] Logged in as', user.email);
        }
      });

      netlifyIdentity.init();
    });
  </script>
  <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
</body>
</html>
