---
interface Props { title?: string; }
const { title = "Portfolio" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Newsreader:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-void text-white min-h-screen">
  <slot />
  <script>
    import { handleAuthCallback, getUser } from '@netlify/identity';

    async function initIdentity() {
      try {
        // Process invite/confirmation/recovery tokens from URL hash.
        // This makes a headless API call — no UI modal is shown.
        const result = await handleAuthCallback();
        if (result) {
          console.log('[Identity] Token processed:', result.type, result.user.email);
          // Token was valid — user is now authenticated. Redirect to admin.
          window.location.href = '/admin/';
          return;
        }

        // No token in URL. Check if already logged in.
        const user = await getUser();
        if (user) {
          console.log('[Identity] Already logged in:', user.email);
          window.location.href = '/admin/';
        }
      } catch (err) {
        console.error('[Identity] Error:', err);
      }
    }

    initIdentity();
  </script>
</body>
</html>
