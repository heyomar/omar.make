---
interface Props { title?: string; }
const { title = "Portfolio" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Newsreader:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-void text-white min-h-screen">
  <slot />
  <script>
    import { handleAuthCallback, getUser } from '@netlify/identity';

    async function init() {
      // Process any invite/confirmation/recovery tokens in URL hash
      const result = await handleAuthCallback();
      if (result) {
        console.log('[Identity] Token processed:', result.type);
        window.location.href = '/admin/';
        return;
      }

      // If already logged in, redirect to admin
      const user = await getUser();
      if (user) {
        if (window.location.pathname !== '/admin/' && window.location.pathname !== '/admin') {
          window.location.href = '/admin/';
        }
      }
    }

    init().catch(console.error);
  </script>
</body>
</html>
