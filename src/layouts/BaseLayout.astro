---
interface Props { title?: string; }
const { title = "Portfolio" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Newsreader:wght@400;700&display=swap" rel="stylesheet" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body class="bg-void text-white min-h-screen">
  <slot />
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof window.netlifyIdentity === 'undefined') {
        console.error('[Identity] Widget script failed to load');
        return;
      }

      // Already logged in? Redirect to admin
      netlifyIdentity.on('init', function(user) {
        if (user) {
          console.log('[Identity] Already logged in as', user.email);
          if (window.location.pathname !== '/admin/' && window.location.pathname !== '/admin') {
            window.location.href = '/admin/';
          }
        } else {
          console.log('[Identity] No active session');
          // Listen for login and redirect
          netlifyIdentity.on('login', function() {
            window.location.href = '/admin/';
          });
        }
      });

      // Handle invite/confirmation tokens in URL
      var hash = window.location.hash;
      if (hash.indexOf('invite_token') !== -1 || hash.indexOf('confirmation_token') !== -1 || hash.indexOf('recovery_token') !== -1) {
        console.log('[Identity] Token detected in URL, processing...');
      }

      netlifyIdentity.init();
    });
  </script>
</body>
</html>
